# ============ JUILE CONFIG ============
# Juile is "bring your own key". Add provider + MCP keys in-app:
#   Settings -> Providers  and  Settings -> Connectors.
# Copy this file to .env if you want optional defaults. Treat .env as secret
# (.gitignore already covers it). Never commit real keys.

# --- AI providers (optional defaults; prefer the in-app Settings) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
OLLAMA_API_KEY=
HF_TOKEN=

# Azure OpenAI (set your resource endpoint + key + deployment)
AZURE_API_KEY=
AZURE_BASE_URL=

# AWS Bedrock (SigV4)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Local runtimes need no key (start their server first).
LMSTUDIO_BASE_URL=http://localhost:1234/v1
OLLAMA_BASE_URL=http://localhost:11434/v1

# --- Web search / deep research ---
TAVILY_API_KEY=

# --- MCP servers (optional; also addable in Settings -> Connectors) ---
COMPOSIO_MCP_URL=https://connect.composio.dev/mcp
COMPOSIO_API_KEY=
ZAPIER_MCP_URL=
HIGGSFIELD_MCP_URL=https://mcp.higgsfield.ai/mcp
HIGGSFIELD_API_KEY=

# --- Behaviour ---
# ask = confirm each action in the UI.  bypass = run actions automatically.
PERMISSION_MODE=ask
HOST=0.0.0.0
PORT=8765
